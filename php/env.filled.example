# ============================================================
# نمونه پر شده - Hamgam روی hamgam.zamanak24.ir
# کپی کنید به php/.env و مقادیر YOUR_* را با اطلاعات واقعی جایگزین کنید
# ============================================================

APP_ENV=production
APP_DEBUG=false
APP_BASE_URL=https://hamgam.zamanak24.ir

# ── Hamdast API Key ───────────────────────────────────────
# از پنل Hamdast > Apps > hamgam > API Keys
HAMDAST_API_KEY=YOUR_HAMDAST_API_KEY

PAZIRESH24_OAUTH_URL=https://hamdast.paziresh24.com/api/v1/apps/hamgam/oauth/access_token
PAZIRESH24_PROFILE_URL=https://apigw.paziresh24.com/open-platform/v1/profile/information
PAZIRESH24_USER_INFO_URL=https://openapi.paziresh24.com/v1/user/information
PAZIRESH24_OPEN_USER_INFO_URL=https://apigw.paziresh24.com/open-platform/v1/user/information
HAMDAST_WIDGETS_URL=https://hamdast.paziresh24.com/api/v1/apps/hamgam/widgets
PAZIRESH24_APPOINTMENT_URL=https://apigw.paziresh24.com/open-platform/v1/booking/appointments
PAZIRESH24_VACATION_URL=https://apigw.paziresh24.com/open-platform/v1/booking/vacations
PAZIRESH24_MEDICAL_CENTERS_URL=https://apigw.paziresh24.com/open-platform/v1/booking/medical-centers

# وب‌هوک نوبت در پنل پذیرش۲۴:
# https://hamgam.zamanak24.ir/php/webhook/paziresh24-hamgam.php
# رویدادها: provider.appointment | provider.appointment.cancelled | provider.appointment.updated
#
# Secret امضای Svix (از پنل Hamdast > Webhooks):
PAZIRESH24_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SIGNING_SECRET

CORS_ORIGINS=https://hamgam.zamanak24.ir,https://www.paziresh24.com,https://hamdast.paziresh24.com

# ── Google OAuth (از Google Cloud Console) ────────────────
GOOGLE_CLIENT_ID=919694018739-dm4m0vgr76dgor65i1prm7dkt4g53vcu.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_OAUTH_CALLBACK_URI=https://hamgam.zamanak24.ir/php/hamgam/google-oauth.php
GOOGLE_OAUTH_SCOPE=https://www.googleapis.com/auth/calendar.events
GOOGLE_CALENDAR_EVENTS_URL=https://www.googleapis.com/calendar/v3/calendars/primary/events
GOOGLE_CALENDAR_WATCH_URL=https://www.googleapis.com/calendar/v3/calendars/primary/events/watch
GOOGLE_CALENDAR_EVENTS_LIST_URL=https://www.googleapis.com/calendar/v3/calendars/primary/events
GOOGLE_CALENDAR_CHANNELS_STOP_URL=https://www.googleapis.com/calendar/v3/channels/stop
GOOGLE_CALENDAR_WEBHOOK_URL=https://hamgam.zamanak24.ir/php/webhook/google-calendar.php

REDIRECT_HOME=https://www.paziresh24.com/
REDIRECT_LAUNCHER=https://www.paziresh24.com/_/hamgam/launcher/
REDIRECT_LAUNCHER_DIRECT=https://www.paziresh24.com/_/hamgam/launcher/?direct=true
REDIRECT_SETTINGS=https://hamgam.zamanak24.ir/

# ── MySQL (از cPanel > MySQL Databases) ───────────────────
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hamgam_db
DB_USER=hamgam_user
DB_PASS=YOUR_DB_PASSWORD

